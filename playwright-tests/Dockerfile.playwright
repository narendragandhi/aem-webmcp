# Playwright Test Runner Container
FROM mcr.microsoft.com/playwright:v1.49.0-noble

WORKDIR /app

# Copy package files
COPY package.json package-lock.json* ./

# Install dependencies
RUN npm ci

# Copy test files
COPY . .

# Install browsers
RUN npx playwright install --with-deps

# Default command
CMD ["npx", "playwright", "test"]
